#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DYNAMIC_DIR="${ROOT_DIR}/infra/traefik/dynamic"

if [[ -f "${ROOT_DIR}/infra/traefik/.env" ]]; then
  set -a
  # shellcheck disable=SC1091
  source "${ROOT_DIR}/infra/traefik/.env"
  set +a
fi

TRAEFIK_HTTP_PORT="${TRAEFIK_HTTP_PORT:-80}"
TRAEFIK_HTTPS_PORT="${TRAEFIK_HTTPS_PORT:-443}"
export TRAEFIK_HTTP_PORT TRAEFIK_HTTPS_PORT

mkdir -p "${DYNAMIC_DIR}"

# Ensure a single shared dashboard route exists for the global ingress.
cat > "${DYNAMIC_DIR}/dashboard.yml" <<'YAML'
http:
  routers:
    traefik-dashboard:
      rule: 'Host(`traefik.localhost`)'
      entryPoints:
        - web
      service: api@internal
YAML

if ! docker network inspect dev-ingress >/dev/null 2>&1; then
  docker network create dev-ingress >/dev/null
fi

docker compose -p local-ingress -f "${ROOT_DIR}/infra/traefik/compose.yml" up -d

suffix=""
if [[ "${TRAEFIK_HTTP_PORT}" != "80" ]]; then
  suffix=":${TRAEFIK_HTTP_PORT}"
fi

echo "Global ingress started: http://traefik.localhost${suffix}"
