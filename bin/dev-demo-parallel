#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BASE_SLUG="$(${ROOT_DIR}/bin/slug.sh)"
A_SLUG="${BASE_SLUG}-a"
B_SLUG="${BASE_SLUG}-b"
HTTP_PORT="${TRAEFIK_HTTP_PORT:-80}"

http_suffix=""
if [[ "${HTTP_PORT}" != "80" ]]; then
  http_suffix=":${HTTP_PORT}"
fi

cmd="${1:-up}"

up_stack() {
  local slug="$1"
  DEV_SLUG="${slug}" COMPOSE_PROJECT_NAME="${slug}" "${ROOT_DIR}/bin/dev-up"
}

down_stack() {
  local slug="$1"
  DEV_SLUG="${slug}" COMPOSE_PROJECT_NAME="${slug}" "${ROOT_DIR}/bin/dev-down"
}

check_stack() {
  local slug="$1"
  local api_host="api-${slug}.localhost"
  local app_host="app-${slug}.localhost"

  echo "Checking ${slug}"
  curl -fsS -H "Host: ${api_host}" "http://127.0.0.1:${HTTP_PORT}/" >/dev/null
  curl -fsS -H "Host: ${app_host}" "http://127.0.0.1:${HTTP_PORT}/" >/dev/null
  echo "- API: ok (${api_host})"
  echo "- App: ok (${app_host})"
}

case "${cmd}" in
  up)
    up_stack "${A_SLUG}"
    up_stack "${B_SLUG}"
    cat <<EOF
Parallel demo stacks started
- ${A_SLUG}
- ${B_SLUG}

URLs
- http://app-${A_SLUG}.localhost${http_suffix}
- http://api-${A_SLUG}.localhost${http_suffix}
- http://app-${B_SLUG}.localhost${http_suffix}
- http://api-${B_SLUG}.localhost${http_suffix}
EOF
    ;;
  down)
    down_stack "${A_SLUG}"
    down_stack "${B_SLUG}"
    echo "Parallel demo stacks stopped: ${A_SLUG}, ${B_SLUG}"
    ;;
  check)
    check_stack "${A_SLUG}"
    check_stack "${B_SLUG}"
    ;;
  *)
    echo "Usage: $0 [up|down|check]"
    exit 1
    ;;
esac
