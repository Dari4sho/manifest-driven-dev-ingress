#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DYNAMIC_DIR="${ROOT_DIR}/infra/traefik/dynamic"

load_env_file() {
  local file="$1"
  if [[ -f "${file}" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "${file}"
    set +a
  fi
}

load_env_file "${ROOT_DIR}/infra/traefik/.env"
load_env_file "${ROOT_DIR}/stack/api/.env"
load_env_file "${ROOT_DIR}/stack/frontend/.env"

DEV_SLUG="${DEV_SLUG:-$(${ROOT_DIR}/bin/slug.sh)}"
COMPOSE_PROJECT_NAME="${COMPOSE_PROJECT_NAME:-${DEV_SLUG}}"
TRAEFIK_HTTP_PORT="${TRAEFIK_HTTP_PORT:-80}"
TRAEFIK_HTTPS_PORT="${TRAEFIK_HTTPS_PORT:-443}"
API_PORT="${API_PORT:-8000}"
FRONTEND_PORT="${FRONTEND_PORT:-3000}"
http_suffix=""
if [[ "${TRAEFIK_HTTP_PORT}" != "80" ]]; then
  http_suffix=":${TRAEFIK_HTTP_PORT}"
fi
API_BASE_URL="${API_BASE_URL:-http://api-${DEV_SLUG}.localhost${http_suffix}}"
VITE_API_BASE_URL="${VITE_API_BASE_URL:-${API_BASE_URL}}"

export DEV_SLUG COMPOSE_PROJECT_NAME TRAEFIK_HTTP_PORT TRAEFIK_HTTPS_PORT API_PORT FRONTEND_PORT API_BASE_URL VITE_API_BASE_URL

mkdir -p "${DYNAMIC_DIR}"

if ! docker network inspect dev-ingress >/dev/null 2>&1; then
  docker network create dev-ingress >/dev/null
fi

docker compose -p local-ingress -f "${ROOT_DIR}/infra/traefik/compose.yml" up -d

docker compose -f "${ROOT_DIR}/stack/compose.yml" up -d --build

cat > "${DYNAMIC_DIR}/${COMPOSE_PROJECT_NAME}.yml" <<EOF
http:
  routers:
    app-${COMPOSE_PROJECT_NAME}:
      rule: 'Host(\`app-${DEV_SLUG}.localhost\`)'
      entryPoints:
        - web
      service: app-${COMPOSE_PROJECT_NAME}
    api-${COMPOSE_PROJECT_NAME}:
      rule: 'Host(\`api-${DEV_SLUG}.localhost\`)'
      entryPoints:
        - web
      service: api-${COMPOSE_PROJECT_NAME}

  services:
    app-${COMPOSE_PROJECT_NAME}:
      loadBalancer:
        servers:
          - url: "http://${COMPOSE_PROJECT_NAME}-frontend-1:${FRONTEND_PORT}"
    api-${COMPOSE_PROJECT_NAME}:
      loadBalancer:
        servers:
          - url: "http://${COMPOSE_PROJECT_NAME}-api-1:${API_PORT}"
EOF

cat <<EOF
Started workspace stack
- DEV_SLUG=${DEV_SLUG}
- COMPOSE_PROJECT_NAME=${COMPOSE_PROJECT_NAME}
- FRONTEND_PORT=${FRONTEND_PORT}
- API_PORT=${API_PORT}
- API_BASE_URL=${API_BASE_URL}

URLs
- App:       http://app-${DEV_SLUG}.localhost${http_suffix}
- API:       http://api-${DEV_SLUG}.localhost${http_suffix}
- Traefik:   http://traefik.localhost${http_suffix}
EOF
