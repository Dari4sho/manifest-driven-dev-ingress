#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DYNAMIC_DIR="${ROOT_DIR}/infra/traefik/dynamic"

load_env_file() {
  local file="$1"
  if [[ -f "${file}" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "${file}"
    set +a
  fi
}

load_env_file "${ROOT_DIR}/infra/traefik/.env"
load_env_file "${ROOT_DIR}/stack/api/.env"
load_env_file "${ROOT_DIR}/stack/frontend/.env"

DEV_SLUG="${DEV_SLUG:-$(${ROOT_DIR}/bin/slug.sh)}"
COMPOSE_PROJECT_NAME="${COMPOSE_PROJECT_NAME:-${DEV_SLUG}}"
TRAEFIK_HTTP_PORT="${TRAEFIK_HTTP_PORT:-80}"
http_suffix=""
if [[ "${TRAEFIK_HTTP_PORT}" != "80" ]]; then
  http_suffix=":${TRAEFIK_HTTP_PORT}"
fi
API_BASE_URL="${API_BASE_URL:-http://api-${DEV_SLUG}.localhost${http_suffix}}"
export DEV_SLUG COMPOSE_PROJECT_NAME API_BASE_URL

docker compose -f "${ROOT_DIR}/stack/compose.yml" down --remove-orphans
rm -f "${DYNAMIC_DIR}/${COMPOSE_PROJECT_NAME}.yml"

echo "Stopped stack for DEV_SLUG=${DEV_SLUG} (project ${COMPOSE_PROJECT_NAME})"
