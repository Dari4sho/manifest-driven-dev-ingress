{
  "name": "demo-local",
  "slug": "auto",
  "compose": {
    "workdir": "../stack",
    "files": ["compose.yml"],
    "project_name_template": "{slug}"
  },
  "env": {
    "API_BASE_URL": "http://{route.api.host}{http_port_suffix}",
    "VITE_API_BASE_URL": "http://{route.api.host}{http_port_suffix}"
  },
  "routes": [
    {
      "name": "app",
      "host": "app-{slug}.localhost",
      "service": {
        "compose_service": "frontend",
        "port": 3000
      }
    },
    {
      "name": "api",
      "host": "api-{slug}.localhost",
      "service": {
        "compose_service": "api",
        "port": 8000
      }
    }
  ]
}
