#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if [[ -f "${ROOT_DIR}/infra/traefik/.env" ]]; then
  set -a
  # shellcheck disable=SC1091
  source "${ROOT_DIR}/infra/traefik/.env"
  set +a
fi

TRAEFIK_HTTP_PORT="${TRAEFIK_HTTP_PORT:-80}"
TRAEFIK_HTTPS_PORT="${TRAEFIK_HTTPS_PORT:-443}"
export TRAEFIK_HTTP_PORT TRAEFIK_HTTPS_PORT

docker compose -p local-ingress -f "${ROOT_DIR}/infra/traefik/compose.yml" down

echo "Global ingress stopped."
