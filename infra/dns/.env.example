# Wildcard dev DNS domain served by local CoreDNS.
INGRESS_DNS_DOMAIN=ingress.test

# Bind DNS listener on host.
INGRESS_DNS_BIND_IP=127.0.0.1
INGRESS_DNS_PORT=53
INGRESS_DNS_UPSTREAM=1.1.1.1 8.8.8.8

# Optional: auto-manage DNS together with `ingress up/down`.
# Set to 1 to run `ingressctl dns up/down` automatically from ingress commands.
INGRESS_DNS_AUTO=0
