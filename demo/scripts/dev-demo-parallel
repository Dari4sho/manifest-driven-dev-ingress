#!/usr/bin/env bash
set -euo pipefail
DEMO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CORE_DIR="$(cd "${DEMO_DIR}/.." && pwd)"
MANIFEST="${DEMO_DIR}/project-local.json"
BASE="$("${CORE_DIR}/bin/ingressctl" stack slug --manifest "${MANIFEST}")"
A="${BASE}-a"
B="${BASE}-b"
DOMAIN="${INGRESS_DEMO_DOMAIN:-test}"
cmd="${1:-up}"

check_ready() {
  local host="$1"
  local url="$2"
  local tries="${3:-30}"
  local i
  for ((i=1; i<=tries; i++)); do
    if curl -fsS -H "Host: ${host}" "${url}" >/dev/null; then
      return 0
    fi
    sleep 1
  done
  return 1
}

case "${cmd}" in
  up)
    "${CORE_DIR}/bin/ingressctl" stack up --manifest "${MANIFEST}" --slug "${A}"
    "${CORE_DIR}/bin/ingressctl" stack up --manifest "${MANIFEST}" --slug "${B}"
    ;;
  down)
    "${CORE_DIR}/bin/ingressctl" stack down --manifest "${MANIFEST}" --slug "${A}"
    "${CORE_DIR}/bin/ingressctl" stack down --manifest "${MANIFEST}" --slug "${B}"
    ;;
  check)
    for s in "${A}" "${B}"; do
      echo "Checking ${s}"
      check_ready "api.${s}.${DOMAIN}" "http://127.0.0.1/healthz"
      check_ready "app.${s}.${DOMAIN}" "http://127.0.0.1/"
      echo "- API: ok (api.${s}.${DOMAIN})"
      echo "- App: ok (app.${s}.${DOMAIN})"
    done
    ;;
  *)
    echo "Usage: $0 [up|down|check]"
    exit 1
    ;;
esac
